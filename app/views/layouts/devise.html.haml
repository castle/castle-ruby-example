      %p.text-center.mb-6
        = link_to root_path, class: 'brand justify-center text-[1.3rem]' do
          %span.brand-dot
          Castle
          %span.text-muted{ style: 'font-weight:400' } demo

      = render 'layouts/messages'

      .card
        = yield

    = render 'layouts/castle_js'
