- flash.each do |name, msg|
  - if msg.is_a?(String)
    %div{ class: "alert alert-#{name.to_s == 'notice' ? 'success' : 'danger'}", role: 'alert' }
      = content_tag :span, msg, id: "flash_#{name}"
      %button.btn-close{ type: 'button', 'data-dismiss-alert' => true, 'aria-label' => 'Close' }
        &times;
